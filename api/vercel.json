{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/alert", "dest": "/api/alert.js" },
    { "src": "/api/cron", "dest": "/api/cron.js" },
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "* * * * *"
    }
  ]
}
